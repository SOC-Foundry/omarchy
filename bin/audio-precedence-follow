#!/usr/bin/env bash
# CHG-007 — pick best hardware sink/source by precedence and keep Rock EQ glued
# to that sink. Safe to run repeatedly (idempotent).
#
# Sink order:  P30i BT → Lenovo USB-C → built-in pro-output-0
# Source order: P30i BT mic → Lenovo USB-C mic → built-in dmic → (never prefer camera)
set -euo pipefail

EQ_SINK="effect_input.eq"
STATE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/audio-eq"
HW_SINK_FILE="$STATE_DIR/hardware-sink"
mkdir -p "$STATE_DIR"

list_sinks()   { pactl list short sinks   2>/dev/null | awk '{print $2}'; }
list_sources() { pactl list short sources 2>/dev/null | awk '{print $2}'; }

sink_exists() {
  list_sinks | rg -qx "$1"
}

source_exists() {
  list_sources | rg -qx "$1"
}

# Return first matching pattern that exists as a live sink
pick_sink() {
  local name
  # 1) soundcore P30i
  while read -r name; do
    [[ -n "$name" ]] || continue
    if sink_exists "$name"; then
      echo "$name"
      return 0
    fi
  done < <(list_sinks | rg 'bluez_output\.F4_B6_2D_75_CE_92' || true)

  # any other bluez A2DP
  while read -r name; do
    [[ -n "$name" ]] || continue
    if sink_exists "$name"; then
      echo "$name"
      return 0
    fi
  done < <(list_sinks | rg 'bluez_output\.' || true)

  # 2) Lenovo USB-C
  while read -r name; do
    [[ -n "$name" ]] || continue
    if sink_exists "$name"; then
      echo "$name"
      return 0
    fi
  done < <(list_sinks | rg 'usb-Synaptics_Lenovo_USB-C_Wired_In-Ear.*analog-stereo' || true)

  # 3) Built-in speakers (pro-output-0 preferred, else stereo-fallback)
  if sink_exists "alsa_output.pci-0000_00_1f.3-platform-sof_sdw.pro-output-0"; then
    echo "alsa_output.pci-0000_00_1f.3-platform-sof_sdw.pro-output-0"
    return 0
  fi
  while read -r name; do
    [[ -n "$name" ]] || continue
    # skip HDMI-ish high channel counts if possible — pro-output-0 already tried
    if [[ "$name" == *sof_sdw* ]] && [[ "$name" != *effect_* ]]; then
      echo "$name"
      return 0
    fi
  done < <(list_sinks | rg 'sof_sdw' || true)

  # last non-EQ hardware
  while read -r name; do
    [[ -n "$name" ]] || continue
    [[ "$name" == "$EQ_SINK" ]] && continue
    [[ "$name" == auto_null* ]] && continue
    echo "$name"
    return 0
  done < <(list_sinks)

  return 1
}

pick_source() {
  local name
  # 1) P30i HFP mic (only present when headset profile active)
  while read -r name; do
    [[ -n "$name" ]] || continue
    [[ "$name" == *.monitor ]] && continue
    echo "$name"
    return 0
  done < <(list_sources | rg 'bluez_input\.F4_B6_2D_75_CE_92' || true)

  while read -r name; do
    [[ -n "$name" ]] || continue
    [[ "$name" == *.monitor ]] && continue
    echo "$name"
    return 0
  done < <(list_sources | rg 'bluez_input\.' || true)

  # 2) Lenovo USB-C mic
  while read -r name; do
    [[ -n "$name" ]] || continue
    [[ "$name" == *.monitor ]] && continue
    echo "$name"
    return 0
  done < <(list_sources | rg 'usb-Synaptics_Lenovo_USB-C_Wired_In-Ear' || true)

  # 3) Built-in dmic
  if source_exists "alsa_input.pci-0000_00_1f.3-platform-sof_sdw.pro-input-1"; then
    echo "alsa_input.pci-0000_00_1f.3-platform-sof_sdw.pro-input-1"
    return 0
  fi
  while read -r name; do
    [[ -n "$name" ]] || continue
    [[ "$name" == *.monitor ]] && continue
    echo "$name"
    return 0
  done < <(list_sources | rg 'sof_sdw\.pro-input' || true)

  # 4) anything else except camera if we can avoid it
  while read -r name; do
    [[ -n "$name" ]] || continue
    [[ "$name" == *.monitor ]] && continue
    [[ "$name" == *Camera* || "$name" == *Sonix* ]] && continue
    echo "$name"
    return 0
  done < <(list_sources)

  # camera only if truly nothing else
  while read -r name; do
    [[ -n "$name" ]] || continue
    [[ "$name" == *.monitor ]] && continue
    echo "$name"
    return 0
  done < <(list_sources)

  return 1
}

move_eq_output_to() {
  local hw="$1"
  local id app name
  # Move any sink-input that looks like the filter-chain EQ playback leg
  while read -r id; do
    [[ -z "$id" ]] && continue
    pactl move-sink-input "$id" "$hw" 2>/dev/null || true
  done < <(
    pactl list sink-inputs 2>/dev/null | awk '
      /^Sink Input #/ { id=$3; gsub("#","",id); app=""; name=""; media="" }
      /application.name/ { app=$0 }
      /node.name/ { name=$0 }
      /media.name/ { media=$0 }
      /media.role/ {
        if (name ~ /effect_output/ || media ~ /EQ / || app ~ /pipewire|filter-chain/ || $0 ~ /DSP/) {
          print id
        }
      }
      /^$/ {
        if (id != "" && (name ~ /effect_output/ || media ~ /EQ /)) print id
      }
    '
  )
  # Broader fallback: node.name contains effect_output
  while read -r id; do
    [[ -z "$id" ]] && continue
    pactl move-sink-input "$id" "$hw" 2>/dev/null || true
  done < <(
    pactl list sink-inputs 2>/dev/null | awk '
      /^Sink Input #/ { id=$3; gsub("#","",id) }
      /node.name/ {
        if ($0 ~ /effect_output/) print id
      }
      /media.name = "EQ / { print id }
    '
  )
}

ensure_default_eq() {
  if sink_exists "$EQ_SINK"; then
    local cur
    cur=$(pactl get-default-sink 2>/dev/null || true)
    if [[ "$cur" != "$EQ_SINK" ]]; then
      pactl set-default-sink "$EQ_SINK" 2>/dev/null || true
    fi
  fi
}

main() {
  local hw src
  hw=$(pick_sink || true)
  src=$(pick_source || true)

  if [[ -n "${hw:-}" ]]; then
    printf '%s\n' "$hw" >"$HW_SINK_FILE"
    move_eq_output_to "$hw"
    # If EQ is not running, default to raw hardware
    if sink_exists "$EQ_SINK"; then
      ensure_default_eq
    else
      pactl set-default-sink "$hw" 2>/dev/null || true
    fi
  fi

  if [[ -n "${src:-}" ]]; then
    pactl set-default-source "$src" 2>/dev/null || true
  fi

  if [[ "${1:-}" == "--print" || "${1:-}" == "status" ]]; then
    echo "hardware_sink=${hw:-none}"
    echo "default_sink=$(pactl get-default-sink 2>/dev/null || echo none)"
    echo "default_source=$(pactl get-default-source 2>/dev/null || echo none)"
    echo "eq_present=$(sink_exists "$EQ_SINK" && echo yes || echo no)"
  fi
}

main "$@"
